# ─────────────────────────────────────────────────────────────────────────────
# QMA Microservices — Environment Variables
# Copy this file to .env and fill in your values.
# docker compose automatically reads .env from the same folder as docker-compose.yml
# ─────────────────────────────────────────────────────────────────────────────

# ── JWT (must be the SAME value across auth-service and qma-service) ─────────
JWT_KEY=QuantityMeasurement_SuperSecretKey_UC17_AtLeast32Chars!
JWT_ISSUER=QuantityMeasurementApi
JWT_AUDIENCE=QuantityMeasurementApi
JWT_EXPIRY_HOURS=24

# ── Google OAuth (only needed if you use /google-login) ──────────────────────
# Get this from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=553292859988-ovtafsja561j1b41gkok1jvcq2hi8hdr.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=*******

# ── SQL Server (optional — leave blank to use in-memory DB) ──────────────────
# Format: Server=host;Database=dbname;User Id=user;Password=pass;
AUTH_DB_CONNECTION=
QMA_DB_CONNECTION=

# ── Ports (change only if 5000/5001/5002/6379 are already in use) ────────────
GATEWAY_PORT=5000
AUTH_PORT=5001
QMA_PORT=5002
REDIS_PORT=6379
